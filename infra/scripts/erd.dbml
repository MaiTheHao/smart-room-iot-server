  "updated_at" datetime(6) [default: NULL]
  "updated_by" varchar(256) [default: NULL]
  "v" bigint [not null]
  "rule_id" bigint [not null]
  "sort_order" int [not null]
  "data_source" varchar(256) [not null, note: 'Enum: SYSTEM, ROOM, DEVICE, SENSOR']
  "resource_param" text [default: NULL, note: 'JSON: { "deviceId": 1, "category": "FAN", "property": "level" }']
  "operator" varchar(5) [not null]
  "value_param" varchar(256) [not null]
  "next_logic" varchar(3) [default: NULL]

  Indexes {
    rule_id [name: "idx_rule_condition_rule_id"]
  }
}

