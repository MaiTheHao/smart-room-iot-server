// feat: Enhance entity definitions with JdbcTypeCode
Table "air_condition" {
  "id" bigint [pk, not null, increment]
  "created_at" datetime(6) [default: NULL]
  "created_by" varchar(256) [default: NULL]
  "updated_at" datetime(6) [default: NULL]
  "updated_by" varchar(256) [default: NULL]
  "v" bigint [not null]
  "is_active" bit(1) [not null]
  "natural_id" varchar(256) [not null]
  "fan_speed" int [default: NULL]
  "mode" varchar(256) [default: NULL]
  "power" varchar(256) [default: NULL]
  "swing" varchar(256) [default: NULL]
  "temperature" int [default: NULL]
  "device_control_id" bigint [default: NULL]
  "room_id" bigint [not null]

  Indexes {
    natural_id [unique, name: "idx_air_condition_natural_id"]
    device_control_id [unique, name: "idx_air_condition_device_control_id"]
    room_id [name: "idx_air_condition_room_id"]
  }
}

Table "air_condition_lan" {
  "id" bigint [pk, not null, increment]
  "created_at" datetime(6) [default: NULL]
  "created_by" varchar(256) [default: NULL]
  "updated_at" datetime(6) [default: NULL]
  "updated_by" varchar(256) [default: NULL]
  "v" bigint [not null]
  "description" text
  "lang_code" varchar(10) [not null]
  "name" varchar(256) [not null]
  "owner_id" bigint [not null]

  Indexes {
    (owner_id, lang_code) [unique, name: "idx_air_condition_lan_owner_id_lang_code"]
  }
}

Table "fan" {
  "id" bigint [pk, not null, increment]
