  "floor_id" bigint [not null]

  Indexes {
    code [unique, name: "idx_room_code"]
    floor_id [name: "idx_room_floor_id"]
  }
}

Table "room_lan" {
  "id" bigint [pk, not null, increment]
  "created_at" datetime(6) [default: NULL]
  "created_by" varchar(256) [default: NULL]
