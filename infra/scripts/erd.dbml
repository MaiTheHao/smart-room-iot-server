}

Table "rule" {
  "id" bigint [pk, not null, increment]
  "created_at" datetime(6) [default: NULL]
  "created_by" varchar(256) [default: NULL]
  "updated_at" datetime(6) [default: NULL]
  "updated_by" varchar(256) [default: NULL]
  "v" bigint [not null]
  "name" varchar(256) [not null]
  "priority" int [not null]
  "is_active" bit(1) [not null, default: `1`]
  "room_id" bigint [not null]
  "target_device_id" bigint [not null]
  "target_device_category" varchar(256) [not null, note: 'Enum: AIR_CONDITION, LIGHT']
  "action_params" text [default: NULL]

  Indexes {
    room_id [name: "idx_rule_room"]
    is_active [name: "idx_rule_status"]
  }
}

Table "rule_condition" {
  "id" bigint [pk, not null, increment]
  "created_at" datetime(6) [default: NULL]
