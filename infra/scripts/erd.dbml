  "mode" varchar(256) [default: NULL]
  "light" varchar(256) [default: NULL]
  "swing" varchar(256) [default: NULL]
  "device_control_id" bigint [default: NULL]
  "room_id" bigint [not null]

  Indexes {
    natural_id [unique, name: "idx_fan_natural_id"]
    device_control_id [unique, name: "idx_fan_device_control_id"]
    room_id [name: "idx_fan_room_id"]
  }
}

